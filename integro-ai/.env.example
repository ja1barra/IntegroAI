# ── Supabase (required) ──────────────────────────────────────
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here

# ── Demo login (optional) ────────────────────────────────────
VITE_DEMO_EMAIL=demo@integroai.com
VITE_DEMO_PASSWORD=your-demo-password-here

# ── Mailbox OAuth (optional — enables real Gmail sending) ─────
# Public OAuth client id for the Google app used to connect a Gmail
# sending mailbox. Same Google Cloud app can back GA4 too.
# The matching GOOGLE_CLIENT_ID / GOOGLE_CLIENT_SECRET must be set as
# SERVER env vars in Vercel (see /.env.example at the repo root).
VITE_GMAIL_CLIENT_ID=your-google-oauth-client-id

# ── CRM API keys (optional) ──────────────────────────────────
# Prospect sync also works by connecting HubSpot/Apollo in the
# Integrations screen; these are only fallbacks for local dev.
# VITE_HUBSPOT_CLIENT_ID=
# VITE_APOLLO_CLIENT_ID=
