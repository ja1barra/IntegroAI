# ============================================================
# Server-side environment variables (set these in Vercel →
# Project → Settings → Environment Variables). They power the
# serverless functions in /api and are NEVER exposed to the browser.
# ============================================================

# ── AI email generation (/api/agent/generate) ────────────────
# Required for live AI-personalized outreach. Without it, the app
# falls back to deterministic mail-merge personalization.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── Gmail sending mailbox (/api/agent/send + OAuth callback) ──
# Google Cloud OAuth app credentials. Enable the Gmail API and add
# scope https://www.googleapis.com/auth/gmail.send. Authorized
# redirect URI: https://YOUR_DOMAIN/api/integrations/oauth-callback
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-client-secret

# ── Other integration OAuth apps (optional) ──────────────────
# SALESFORCE_CLIENT_ID=
# SALESFORCE_CLIENT_SECRET=
# OUTREACH_CLIENT_ID=
# OUTREACH_CLIENT_SECRET=
# LINKEDIN_CLIENT_ID=
# LINKEDIN_CLIENT_SECRET=
# INTERCOM_CLIENT_ID=
# INTERCOM_CLIENT_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
